{
	"name": "the-ai-interrogation",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix && prettier --write .",
		"format": "prettier --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"prepare": "husky"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.14.0",
		"motion": "^12.38.0",
		"next": "16.2.4",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"shadcn": "^4.6.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9",
		"eslint-config-next": "16.2.4",
		"eslint-plugin-tailwindcss": "^3.18.3",
		"husky": "^9.1.7",
		"jsdom": "^29.1.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.5"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	}
}
